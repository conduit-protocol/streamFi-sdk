{
  "compilerOptions": {
    "target":                          "ES2022",
    "lib":                             ["ES2022"],
    "module":                          "ESNext",
    "moduleResolution":                "Bundler",
    "strict":                          true,
    "noUncheckedIndexedAccess":        true,
    "exactOptionalPropertyTypes":      true,
    "forceConsistentCasingInFileNames": true,
    "declaration":                     false,
    "rootDir":                         "src",
    "skipLibCheck":                    true,
    "esModuleInterop":                 true,
    "resolveJsonModule":               true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "examples", "src/tests"]
}
